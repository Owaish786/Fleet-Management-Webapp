generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  IDLE
}

enum DriverStatus {
  AVAILABLE
  ON_ROUTE
  OFF_DUTY
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

model Vehicle {
  id                 String              @id @default(cuid())
  plateNumber        String              @unique
  make               String
  model              String
  year               Int
  mileage            Int
  status             VehicleStatus
  assignedDriverId   String?             @unique
  assignedDriver     Driver?             @relation(fields: [assignedDriverId], references: [id])
  trips              Trip[]
  maintenanceRecords MaintenanceRecord[]
  locationPings      VehicleLocationPing[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Driver {
  id               String         @id @default(cuid())
  name             String
  licenseNumber    String         @unique
  phone            String
  status           DriverStatus
  joinedAt         DateTime       @default(now())
  assignedVehicles Vehicle[]
  trips            Trip[]
  locationPings    VehicleLocationPing[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Trip {
  id             String     @id @default(cuid())
  routeName      String
  origin         String
  destination    String
  departureAt    DateTime
  arrivalAt      DateTime?
  distanceKm     Int
  status         TripStatus
  fuelUsedLiters Float?
  notes          String?
  vehicleId      String
  driverId       String
  vehicle        Vehicle    @relation(fields: [vehicleId], references: [id])
  driver         Driver     @relation(fields: [driverId], references: [id])
  locationPings  VehicleLocationPing[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model MaintenanceRecord {
  id           String            @id @default(cuid())
  type         String
  status       MaintenanceStatus
  scheduledFor DateTime
  completedAt  DateTime?
  cost         Decimal?          @db.Decimal(10, 2)
  notes        String?
  vehicleId    String
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model VehicleLocationPing {
  id           String   @id @default(cuid())
  vehicleId    String
  driverId     String?
  tripId       String?
  latitude     Float
  longitude    Float
  speedKph     Float?
  headingDeg   Float?
  accuracyM    Float?
  batteryLevel Int?
  recordedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  trip    Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId, recordedAt(sort: Desc)])
  @@index([driverId, recordedAt(sort: Desc)])
  @@index([tripId, recordedAt(sort: Desc)])
}